# Normalize line endings.
# Text files use LF in the repo; Windows checkouts still see CRLF in-working-tree
# thanks to core.autocrlf, but the object store is stable across OSes.
* text=auto eol=lf

# Shell scripts must stay LF or they break inside Alpine / Docker containers.
*.sh text eol=lf

# Lockfiles — keep mergeable with an explicit union driver note, though we do
# NOT actually register a custom merger; this just documents intent.
package-lock.json text eol=lf

# Binaries — don't normalize.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary

# Copy to .env and adjust before running `docker compose up`.

# REQUIRED — change in any non-throwaway environment.
JWT_SECRET=change-me-to-a-long-random-string-please

# MySQL credentials (defaults are fine for local dev).
MYSQL_ROOT_PASSWORD=rootpw
DB_NAME=qa_community
DB_USER=qa_user
DB_PASSWORD=qa_pass

# JWT lifetime (zeit/ms format).
JWT_EXPIRES_IN=7d

# Daily passive points cap (likes received, accepted bonuses, etc.).
DAILY_PASSIVE_POINTS_CAP=200

# Comma-separated extra banned words on top of the built-in list.
BANNED_WORDS=

# Host port that exposes the nginx-served frontend.
FRONTEND_PORT=8080

# CORS whitelist — comma-separated origins allowed to call the API with
# credentials / from a different host. Leave empty in local dev (permissive).
# In production, set to the public frontend origin, e.g.
#   ALLOWED_ORIGINS=https://qa.example.com,https://admin.example.com
ALLOWED_ORIGINS=

# Disable rate limiting for local iteration. Default is ON in every env
# except NODE_ENV=test. Leave unset in production.
# RATE_LIMIT_DISABLE=1

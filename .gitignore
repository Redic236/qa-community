# Dependencies and build output (each subproject also has its own .gitignore)
node_modules/
dist/
build/
.cache/
.vite/
.turbo/

# TypeScript incremental build cache — local churn, shouldn't be tracked
*.tsbuildinfo

# Logs
*.log
npm-debug.log*

# Environment / secrets
.env
.env.local
.env.*.local

# Editor / OS
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# Test artifacts
coverage/
playwright-report/
test-results/

# Docker local bind mounts (named volumes don't show up here)
mysql_data/
redis_data/

# Runtime user uploads — written by the server, never tracked
backend/uploads/
uploads/

# Local scratch for GitHub Release note drafts — not shipped
.release-notes/

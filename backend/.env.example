NODE_ENV=development
PORT=3000

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=qa_community

JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Comma-separated banned substrings; empty disables checks. Defaults to a small
# CN-spam list bundled in ModerationService.ts when the var is unset.
# BANNED_WORDS=联系微信,加我QQ,免费送

# Max positive passive points (likes / accepted bonuses) per user per UTC day.
# 0 disables the cap. Default 100.
# DAILY_PASSIVE_POINTS_CAP=100

# Optional Redis. When set:
#   - rate limiter shares state across instances (rate-limit-redis)
#   - GET /api/questions/:id is cached (anon shape, 60s TTL, invalidated on writes)
# Leave unset for single-instance dev — code falls back to in-memory cleanly.
# REDIS_URL=redis://localhost:6379

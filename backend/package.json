{
  "name": "qa-community-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Q&A community backend - Express + Sequelize + MySQL",
  "main": "dist/app.js",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "smoke": "tsx scripts/smoke.ts",
    "db:create": "tsx scripts/db-create.ts",
    "db:inspect": "tsx scripts/db-inspect.ts",
    "db:migrate": "tsx src/db/migrate.ts up",
    "db:migrate:down": "tsx src/db/migrate.ts down",
    "db:migrate:status": "tsx src/db/migrate.ts status",
    "db:setup": "npm run db:create && npm run db:migrate",
    "db:promote-admin": "tsx scripts/promote-admin.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^8.1.0",
    "i18next": "^26.0.6",
    "i18next-http-middleware": "^3.9.3",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "mysql2": "^3.11.0",
    "rate-limit-redis": "^4.2.0",
    "sequelize": "^6.37.3",
    "tsx": "^4.21.0",
    "umzug": "^3.8.1",
    "winston": "^3.13.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.14.10",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "sqlite3": "^5.1.7",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.2",
    "typescript": "^5.5.3"
  }
}
